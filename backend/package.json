{
  "name": "shram-swasthya-portal",
  "version": "1.0.0",
  "description": "Backend for Shram Swasthya Portal",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
